# Storage backend: "local" (JSON files) or "dynamodb"
STORAGE_TYPE=local

# Local file storage directory (only used when STORAGE_TYPE=local)
# Defaults to ./data/ relative to the server directory
LOCAL_STORAGE_DIR=./data

# AWS Configuration (only used when STORAGE_TYPE=dynamodb)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB Configuration (only used when STORAGE_TYPE=dynamodb)
DYNAMODB_TABLE_NAME=plant-planner-plots

# Set to "true" to use local DynamoDB (e.g. for development)
DYNAMODB_LOCAL=true
DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000

# Server
PORT=3001
